# Variables de entorno para Oracle Fusion Agentic Apps
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ── Oracle Fusion REST API ─────────────────────────────────────────────────
# URL base de tu instancia Oracle Fusion (sin barra final)
# Ejemplo: https://your-instance.oraclecloud.com
FUSION_BASE_URL=

# Usuario con acceso a la API REST de Oracle Fusion
FUSION_USERNAME=

# Contraseña del usuario (guarda en un gestor de secretos en producción)
FUSION_PASSWORD=

# ── Orquestador ────────────────────────────────────────────────────────────
# Directorio donde residen los archivos YAML de workflows
WORKFLOWS_DIR=workflows

# Puerto en el que escucha el orquestador
PORT=8000
